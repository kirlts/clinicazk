---
import MembershipCard from '../content/MembershipCard.astro';
import { memberships } from '../../data/site';
---

<section id="membresias" class="zk-memberships">
  <div class="zk-container">
    <div class="zk-memberships__head">
      <h2 class="zk-memberships__title">
        Algunos reaccionan. <span class="zk-memberships__accent">Otros se anticipan.</span>
      </h2>
      <p class="zk-memberships__intro">
        Las membresías anuales Familia ZK son una nueva forma de cuidar tu salud dental: con orden,
        controles al día y respaldo ante urgencias, en Los Ángeles y Pucón. Elige la que va contigo.
      </p>
    </div>

    <div class="zk-memberships__grid">
      {memberships.map((mb) => (
        <MembershipCard
          membership={mb.m}
          name={mb.name}
          motto={mb.motto}
          headline={mb.headline}
          tagline={mb.tag}
          features={mb.feats}
          ctaLabel="Ver más"
          ctaHref={`${import.meta.env.BASE_URL}afiche/${mb.m}/`}
          highlighted={mb.hl}
        />
      ))}
    </div>
  </div>
</section>

<style>
  .zk-memberships {
    background: linear-gradient(
      to bottom,
      var(--zk-white),
      var(--surface-section) 9%,
      var(--surface-section) 91%,
      var(--zk-white)
    );
    padding: 52px 24px;
  }
  .zk-memberships__head {
    text-align: center;
  }
  .zk-memberships__title {
    color: var(--text-heading);
    font-size: var(--fs-h1);
    font-weight: var(--fw-light);
    margin: 0;
    line-height: var(--lh-tight);
  }
  .zk-memberships__accent {
    font-weight: var(--fw-semibold);
    color: var(--zk-teal-600);
  }
  .zk-memberships__intro {
    color: var(--text-body);
    font-size: var(--fs-body-lg);
    margin: 18px auto 0;
    max-width: 1180px;
    line-height: var(--lh-body);
    text-wrap: pretty;
  }
  .zk-memberships__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 18px;
    margin-top: 44px;
    align-items: stretch;
  }
  @media (max-width: 980px) {
    .zk-memberships__grid {
      grid-template-columns: 1fr 1fr;
    }
  }
  @media (max-width: 560px) {
    .zk-memberships__grid {
      grid-template-columns: 1fr;
    }
  }
</style>

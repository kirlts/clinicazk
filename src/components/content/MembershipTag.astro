---
import { Image } from 'astro:assets';
import isotipo from '../../assets/brand/isotipo.png';

interface Props {
  membership: 'anticipa' | 'familia' | 'seguimiento' | 'total';
  name: string;
  motto?: string;
  size?: 'sm' | 'md';
}

const GRAD = {
  anticipa:
    'radial-gradient(130% 100% at 20% 8%, #63C6C0 0%, rgba(99,198,192,0) 52%), linear-gradient(158deg, #46B3AD 0%, #2E9A94 60%, #1E827D 100%)',
  familia:
    'radial-gradient(130% 100% at 20% 8%, #C8B0D4 0%, rgba(200,176,212,0) 52%), linear-gradient(158deg, #B094BF 0%, #916F9F 60%, #775A80 100%)',
  seguimiento:
    'radial-gradient(130% 100% at 20% 8%, #E2E3E4 0%, rgba(226,227,228,0) 52%), linear-gradient(158deg, #C6C8C9 0%, #ABADAF 55%, #909294 100%)',
  total:
    'radial-gradient(130% 100% at 20% 8%, #63676B 0%, rgba(99,103,107,0) 52%), linear-gradient(158deg, #4C5053 0%, #34383B 60%, #23262A 100%)',
};

const { membership, name, motto, size = 'md' } = Astro.props;

const grad = GRAD[membership] ?? GRAD.anticipa;
const parts = name.trim().split(/\s+/);
const brand = parts.length > 1 ? parts[0] : 'ZK';
const label = parts.length > 1 ? parts.slice(1).join(' ') : name;

const dims =
  size === 'sm'
    ? { width: 190, radius: 20, pad: 20, nameSize: 21, mottoSize: 16, mottoGap: 20, logo: 34, top: 30 }
    : { width: 250, radius: 28, pad: 26, nameSize: 28, mottoSize: 21, mottoGap: 26, logo: 46, top: 40 };
---

<div
  class="zk-tag"
  style={`width:${dims.width}px;border-radius:${dims.radius}px;background:${grad};padding:${dims.pad}px`}
>
  <span
    class="zk-tag__mark"
    style={`top:${dims.pad - 4}px;right:${dims.pad - 4}px;width:${dims.logo}px;height:${dims.logo}px`}
  >
    <Image src={isotipo} alt="" width={Math.round(dims.logo * 0.72)} height={Math.round(dims.logo * 0.72 * 1.02)} />
  </span>

  <div
    class="zk-tag__brand"
    style={`margin-top:${dims.top}px;font-size:${dims.nameSize}px`}
  >
    <div>{brand}</div>
    <div>{label}</div>
  </div>

  {motto && (
    <div class="zk-tag__motto" style={`margin-top:${dims.mottoGap}px;font-size:${dims.mottoSize}px`}>
      {motto}
    </div>
  )}

  <svg viewBox="0 0 250 96" preserveAspectRatio="none" aria-hidden="true" class="zk-tag__wave">
    <path d="M40 92 C 130 58, 190 60, 262 20" fill="none" stroke="#fff" stroke-width="1.2"></path>
    <path d="M96 96 C 160 74, 205 74, 262 46" fill="none" stroke="#fff" stroke-width="1" opacity=".7"></path>
  </svg>
</div>

<style>
  .zk-tag {
    position: relative;
    aspect-ratio: 1 / 1.36;
    color: #fff;
    box-sizing: border-box;
    display: flex;
    flex-direction: column;
    overflow: hidden;
    box-shadow: 0 22px 44px -18px rgba(0, 0, 0, 0.4);
    flex-shrink: 0;
  }
  .zk-tag__mark {
    position: absolute;
    border-radius: 50%;
    background: #fff;
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }
  .zk-tag__brand {
    font-weight: var(--fw-light);
    letter-spacing: 0.04em;
    line-height: 1.5;
    text-transform: uppercase;
  }
  .zk-tag__motto {
    font-weight: var(--fw-light);
    letter-spacing: 0.04em;
    text-transform: uppercase;
    line-height: 1.5;
    opacity: 0.95;
    max-width: 86%;
  }
  .zk-tag__wave {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    width: 100%;
    height: 96px;
    opacity: 0.38;
  }
</style>

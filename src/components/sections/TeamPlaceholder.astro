<section id="equipo" class="zk-team">
  <div class="zk-container">
    <h2 class="zk-team__title">Nuestro Equipo</h2>
    <div class="zk-team__box">
      <div class="zk-team__box-title">Sección en preparación</div>
      <p class="zk-team__box-text">
        Estamos reuniendo las fotos y datos de nuestro equipo de especialistas. Preferimos publicar información real y verificada antes que apurar esta sección.
      </p>
    </div>
  </div>
</section>

<style>
  .zk-team {
    background: var(--surface-section);
    padding: var(--space-9) 24px;
  }
  .zk-team__title {
    font-size: var(--fs-h2);
    margin: 0;
    text-align: right;
    color: var(--text-heading);
    font-weight: var(--fw-semibold);
  }
  .zk-team__box {
    margin-top: 24px;
    border: 1.5px dashed var(--zk-teal-200);
    background: var(--zk-white);
    padding: 32px 30px;
    max-width: 640px;
  }
  .zk-team__box-title {
    font-size: 15px;
    font-weight: var(--fw-semibold);
    color: var(--text-heading);
  }
  .zk-team__box-text {
    font-size: 14px;
    color: var(--text-body);
    line-height: 1.6;
    margin: 8px 0 0;
  }
</style>

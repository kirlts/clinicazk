---
import Button from '../core/Button.astro';
import BranchSplit from '../content/BranchSplit.astro';
import { quickLinks } from '../../data/site';
---

<section id="inicio" class="zk-hero">
  <div class="zk-container">
    <h1 class="zk-hero__h1">
      Tu salud dental, <span class="zk-hero__accent">en orden.</span>
    </h1>

    <div class="zk-hero__quick">
      {quickLinks.map((q) => (
        <a href="#especialidades" data-espec-idx={q.idx} class="zk-hero__quick-link">{q.label}</a>
      ))}
    </div>

    <div class="zk-hero__split">
      <BranchSplit height={680} />
    </div>

    <div class="zk-hero__foot">
      <p class="zk-hero__lead">
        Un buen tratamiento empieza por un buen diagnóstico<span class="zk-hero__dot">.</span>
      </p>
      <Button size="lg" href="#contacto">Agenda tu evaluación</Button>
    </div>
  </div>
</section>

<style>
  .zk-hero {
    padding: 60px 24px 0;
  }
  .zk-hero__h1 {
    font-size: clamp(42px, 5.6vw, 82px);
    font-weight: var(--fw-light);
    line-height: 1.08;
    color: var(--text-heading);
    margin: 0;
    letter-spacing: -0.01em;
  }
  .zk-hero__accent {
    color: var(--color-primary);
    font-weight: var(--fw-regular);
  }
  .zk-hero__quick {
    margin-top: 26px;
    display: grid;
    grid-template-columns: repeat(5, 1fr);
  }
  .zk-hero__quick-link {
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 16px 14px;
    text-decoration: none;
    color: var(--text-heading);
    font-size: 16.5px;
    transition: color 0.18s var(--ease-out);
  }
  .zk-hero__quick-link + .zk-hero__quick-link {
    border-left: 1px solid var(--border-subtle);
  }
  .zk-hero__quick-link:hover {
    color: var(--zk-teal-600);
    text-decoration: none;
  }
  .zk-hero__split {
    margin-top: 20px;
  }
  .zk-hero__foot {
    margin-top: 26px;
    border-top: 1px solid var(--border-subtle);
    padding-top: 26px;
    display: grid;
    grid-template-columns: 1fr auto;
    align-items: center;
    gap: 20px 48px;
  }
  .zk-hero__lead {
    font-size: clamp(22px, 2vw, 30px);
    font-weight: var(--fw-light);
    color: var(--text-heading);
    margin: 0;
    line-height: var(--lh-tight);
    text-wrap: pretty;
  }
  .zk-hero__dot {
    color: var(--zk-teal-600);
  }

  @media (max-width: 720px) {
    .zk-hero__quick {
      grid-template-columns: repeat(2, 1fr);
    }
    .zk-hero__quick-link:nth-child(odd) {
      border-left: none;
    }
    .zk-hero__quick-link {
      border-top: 1px solid var(--border-subtle);
    }
    .zk-hero__foot {
      grid-template-columns: 1fr;
      justify-items: start;
    }
  }
</style>

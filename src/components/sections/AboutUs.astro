---
import { Image } from 'astro:assets';
import isotipo from '../../assets/brand/isotipo.png';
import SectionHeader from '../core/SectionHeader.astro';
---

<section id="nosotros" class="zk-about">
  <div class="zk-container zk-about__grid">
    <div class="zk-about__placeholder">
      <div class="zk-about__placeholder-inner">
        <Image src={isotipo} alt="" width={90} height={92} />
        <div class="zk-about__pending">FOTO DE LA CLÍNICA · PENDIENTE</div>
      </div>
    </div>
    <div>
      <SectionHeader
        align="left"
        title="Diez años cuidando sonrisas en el sur"
        subtitle="Nacimos en Los Ángeles hace una década y crecimos hasta Pucón con una convicción: la salud dental se cuida mejor cuando se cuida antes. [Texto definitivo pendiente del director]"
      />
      <div class="zk-about__stats">
        <div>
          <div class="zk-about__stat-num">10+</div>
          <div class="zk-about__stat-label">años de experiencia</div>
        </div>
        <div>
          <div class="zk-about__stat-num">2</div>
          <div class="zk-about__stat-label">sucursales</div>
        </div>
        <div>
          <div class="zk-about__stat-num">5</div>
          <div class="zk-about__stat-label">especialidades</div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .zk-about {
    padding: var(--space-9) 24px;
  }
  .zk-about__grid {
    display: grid;
    grid-template-columns: 0.9fr 1.1fr;
    gap: 48px;
    align-items: center;
  }
  .zk-about__placeholder {
    height: 340px;
    border-radius: var(--radius-lg);
    border: 1.5px dashed var(--zk-teal-200);
    background: var(--zk-teal-50);
    display: grid;
    place-items: center;
  }
  .zk-about__placeholder-inner {
    text-align: center;
  }
  .zk-about__placeholder-inner :global(img) {
    opacity: 0.45;
  }
  .zk-about__pending {
    font-size: 12px;
    letter-spacing: 0.06em;
    color: var(--text-muted);
    font-weight: 600;
    margin-top: 12px;
  }
  .zk-about__stats {
    display: flex;
    gap: 36px;
    margin-top: 28px;
    flex-wrap: wrap;
  }
  .zk-about__stat-num {
    font-size: 34px;
    font-weight: var(--fw-bold);
    color: var(--zk-teal-600);
  }
  .zk-about__stat-label {
    font-size: 15px;
  }

  @media (max-width: 900px) {
    .zk-about__grid {
      grid-template-columns: 1fr;
      gap: 32px;
    }
    .zk-about__placeholder {
      height: 240px;
    }
  }
</style>

---
import SectionHeader from '../core/SectionHeader.astro';
import FaqItem from '../content/FaqItem.astro';
import { faqs } from '../../data/site';
---

<section id="faq" class="zk-faq-section">
  <div class="zk-container">
    <SectionHeader align="left" title="Preguntas frecuentes" />
    <div class="zk-faq-section__list">
      {faqs.map((f) => (
        <FaqItem question={f.q} answer={f.a} />
      ))}
    </div>
  </div>
</section>

<style>
  .zk-faq-section {
    padding: var(--space-9) 24px;
  }
  .zk-faq-section__list {
    max-width: 760px;
    margin: 28px 0 0;
  }
</style>

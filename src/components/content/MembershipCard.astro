---
import { Image } from 'astro:assets';
import isotipo from '../../assets/brand/isotipo.png';
import Button from '../core/Button.astro';

interface Props {
  membership: 'anticipa' | 'familia' | 'seguimiento' | 'total';
  name: string;
  motto: string;
  headline: string;
  tagline: string;
  features: readonly string[];
  ctaLabel: string;
  ctaHref: string;
  highlighted?: boolean;
}

const ACCENTS = {
  anticipa: 'var(--zk-anticipa)',
  familia: 'var(--zk-familia)',
  seguimiento: 'var(--zk-seguimiento)',
  total: 'var(--zk-total)',
};

const GRAD = {
  anticipa:
    'radial-gradient(130% 120% at 18% 0%, #63C6C0 0%, rgba(99,198,192,0) 55%), linear-gradient(105deg, #46B3AD 0%, #2E9A94 60%, #1E827D 100%)',
  familia:
    'radial-gradient(130% 120% at 18% 0%, #C8B0D4 0%, rgba(200,176,212,0) 55%), linear-gradient(105deg, #B094BF 0%, #916F9F 60%, #775A80 100%)',
  seguimiento:
    'radial-gradient(130% 120% at 18% 0%, #E2E3E4 0%, rgba(226,227,228,0) 55%), linear-gradient(105deg, #C6C8C9 0%, #ABADAF 55%, #909294 100%)',
  total:
    'radial-gradient(130% 120% at 18% 0%, #63676B 0%, rgba(99,103,107,0) 55%), linear-gradient(105deg, #4C5053 0%, #34383B 60%, #23262A 100%)',
};

const { membership, name, motto, headline, tagline, features, ctaLabel, ctaHref, highlighted = false } =
  Astro.props;

const accent = ACCENTS[membership] ?? ACCENTS.anticipa;
const grad = GRAD[membership] ?? GRAD.anticipa;
const parts = name.trim().split(/\s+/);
const brand = parts.length > 1 ? parts[0] : 'ZK';
const label = parts.length > 1 ? parts.slice(1).join(' ') : name;
---

<div class="zk-mcard" data-highlighted={highlighted ? '' : undefined} style={highlighted ? `border-color:${accent}` : ''}>
  <div class="zk-mcard__banner" style={`background:${grad}`}>
    <span class="zk-mcard__mark">
      <Image src={isotipo} alt="" width={27} height={28} />
    </span>
    <div class="zk-mcard__brand">
      <div>{brand}</div>
      <div>{label}</div>
    </div>
    {motto && <div class="zk-mcard__motto">{motto}</div>}
    <svg viewBox="0 0 320 60" preserveAspectRatio="none" aria-hidden="true" class="zk-mcard__wave">
      <path d="M120 58 C 200 34, 250 36, 340 8" fill="none" stroke="#fff" stroke-width="1.1"></path>
    </svg>
  </div>

  <div class="zk-mcard__body">
    <p class="zk-mcard__headline">{headline}</p>
    <p class="zk-mcard__tagline">{tagline}</p>
    <ul class="zk-mcard__feats">
      {features.map((feat) => (
        <li>
          <span style={`color:${accent}`}>✓</span>
          {feat}
        </li>
      ))}
    </ul>
    <div class="zk-mcard__cta">
      <Button
        variant={highlighted ? 'primary' : 'outline'}
        size="sm"
        href={ctaHref}
        style={highlighted ? `background:${accent};box-shadow:none` : `color:${accent};border-color:${accent}`}
      >
        {ctaLabel}
      </Button>
    </div>
  </div>
</div>

<style>
  .zk-mcard {
    display: flex;
    flex-direction: column;
    background: var(--surface-card);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-card);
    overflow: hidden;
    border: 1px solid var(--border-subtle);
    height: 100%;
    box-sizing: border-box;
  }
  .zk-mcard[data-highlighted] {
    border-width: 2px;
    box-shadow: var(--shadow-raised);
  }
  .zk-mcard__banner {
    position: relative;
    color: #fff;
    padding: 22px 24px 24px;
    overflow: hidden;
    min-height: 184px;
    box-sizing: border-box;
  }
  .zk-mcard__mark {
    position: absolute;
    top: 16px;
    right: 18px;
    width: 38px;
    height: 38px;
    border-radius: 50%;
    background: #fff;
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }
  .zk-mcard__brand {
    position: relative;
    z-index: 1;
    font-size: 21px;
    font-weight: var(--fw-light);
    letter-spacing: 0.04em;
    line-height: 1.5;
    text-transform: uppercase;
  }
  .zk-mcard__motto {
    position: relative;
    z-index: 1;
    margin-top: 14px;
    font-size: 16px;
    font-weight: var(--fw-light);
    letter-spacing: 0.04em;
    text-transform: uppercase;
    line-height: 1.5;
    opacity: 0.95;
    max-width: 80%;
    min-height: 48px;
  }
  .zk-mcard__wave {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    width: 100%;
    height: 60px;
    opacity: 0.34;
  }
  .zk-mcard__body {
    padding: 20px 24px 24px;
    display: flex;
    flex-direction: column;
    gap: 14px;
    flex: 1;
  }
  .zk-mcard__headline {
    margin: 0;
    font-size: 17px;
    font-weight: var(--fw-semibold);
    color: var(--text-heading);
    line-height: 1.3;
  }
  .zk-mcard__tagline {
    margin: 0;
    font-size: 15px;
    color: var(--text-body);
  }
  .zk-mcard__feats {
    margin: 0;
    padding: 0;
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .zk-mcard__feats li {
    display: flex;
    gap: 10px;
    font-size: 15px;
    color: var(--text-body);
  }
  .zk-mcard__feats li span {
    font-weight: var(--fw-bold);
    line-height: 1.5;
  }
  .zk-mcard__cta {
    margin-top: auto;
    padding-top: 8px;
  }
</style>

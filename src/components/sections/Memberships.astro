---
import SectionHeader from '../core/SectionHeader.astro';
import MembershipCard from '../content/MembershipCard.astro';
import { memberships, waPuconLink } from '../../data/site';
---

<section class="zk-memberships">
  <div class="zk-container">
    <SectionHeader align="left" title="Algunos reaccionan. Otros se anticipan." />
    <div class="zk-memberships__grid">
      {memberships.map((mb) => (
        <MembershipCard
          membership={mb.m}
          name={mb.name}
          motto={mb.motto}
          headline={mb.headline}
          tagline={mb.tag}
          features={mb.feats}
          ctaLabel="Consultar por WhatsApp"
          ctaHref={`${waPuconLink}?text=${encodeURIComponent(`Hola, quisiera más información sobre la membresía ${mb.name}.`)}`}
          highlighted={mb.hl}
        />
      ))}
    </div>
    <p class="zk-memberships__disclaimer">
      Tu membresía no reemplaza la evaluación clínica profesional. Prestaciones, controles e indicaciones sujetas al diagnóstico del equipo tratante.
    </p>
  </div>
</section>

<style>
  .zk-memberships {
    background: var(--surface-section);
    padding: var(--space-9) 24px;
  }
  .zk-memberships__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 18px;
    margin-top: 44px;
    align-items: stretch;
  }
  .zk-memberships__disclaimer {
    font-size: var(--fs-caption);
    color: var(--text-muted);
    margin-top: 24px;
    max-width: 640px;
    line-height: var(--lh-body);
  }

  @media (max-width: 980px) {
    .zk-memberships__grid {
      grid-template-columns: 1fr 1fr;
    }
  }
  @media (max-width: 560px) {
    .zk-memberships__grid {
      grid-template-columns: 1fr;
    }
  }
</style>

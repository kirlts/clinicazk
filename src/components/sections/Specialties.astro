---
import SectionHeader from '../core/SectionHeader.astro';
import { specialties } from '../../data/site';

const TEAL = 'var(--zk-teal-600)';
const PURPLE = 'var(--color-secondary)';
const GRAD_LA =
  'radial-gradient(130% 120% at 18% 0%, #63C6C0 0%, rgba(99,198,192,0) 55%), linear-gradient(105deg, #46B3AD 0%, #2E9A94 60%, #1E827D 100%)';
const GRAD_PU =
  'radial-gradient(130% 120% at 18% 0%, #C8B0D4 0%, rgba(200,176,212,0) 55%), linear-gradient(105deg, #B094BF 0%, #916F9F 60%, #775A80 100%)';

// Datos derivados para el maestro-detalle (se serializan al script del cliente).
const espec = specialties.map((s, i) => {
  const only = (s as { only?: string }).only ?? '';
  const onlyColor = only === 'la' ? TEAL : only === 'pucon' ? PURPLE : '';
  const prevOnly = (specialties[i - 1] as { only?: string } | undefined)?.only ?? '';
  const groupLabel =
    only && only !== prevOnly ? (only === 'la' ? 'Solo en Los Ángeles' : 'Solo en Pucón') : '';
  const contacts = [
    !only || only === 'la' ? { city: 'Los Ángeles', sede: 'Los Ángeles', grad: GRAD_LA } : null,
    !only || only === 'pucon' ? { city: 'Pucón', sede: 'Pucón', grad: GRAD_PU } : null,
  ].filter(Boolean);
  return {
    title: s.title,
    desc: s.desc,
    only,
    onlyColor,
    groupLabel,
    sedeLine:
      only === 'la'
        ? 'Disponible solo en Los Ángeles'
        : only === 'pucon'
          ? 'Disponible solo en Pucón'
          : 'Disponible en ambas sedes',
    sedeColor: only ? onlyColor : TEAL,
    descText: s.desc || 'Texto informativo de esta especialidad en preparación con el equipo clínico.',
    descColor: s.desc ? 'var(--text-body)' : 'var(--text-muted)',
    contacts,
  };
});
---

<section id="especialidades" class="zk-esp">
  <div class="zk-container">
    <SectionHeader align="left" title="Especialidades" />

    <div class="zk-esp__grid">
      <div class="zk-esp__list" role="tablist" aria-label="Especialidades" id="zk-esp-list">
        {espec.map((s, i) => (
          <div>
            {s.groupLabel && (
              <div class="zk-esp__group" style={`color:${s.onlyColor}`}>{s.groupLabel}</div>
            )}
            <button
              type="button"
              role="tab"
              aria-selected={i === 0 ? 'true' : 'false'}
              data-idx={i}
              class="zk-esp__row"
            >
              <span class="zk-esp__name">{s.title}</span>
            </button>
          </div>
        ))}
      </div>

      <div class="zk-esp__panel" id="zk-esp-panel" role="tabpanel" aria-live="polite"></div>
    </div>
  </div>

  <script type="application/json" id="zk-esp-data" is:inline set:html={JSON.stringify(espec)}></script>
</section>

<script>
  type Contact = { city: string; sede: string; grad: string };
  type Espec = {
    title: string;
    sedeLine: string;
    sedeColor: string;
    descText: string;
    descColor: string;
    contacts: Contact[];
  };

  const dataEl = document.getElementById('zk-esp-data');
  const panel = document.getElementById('zk-esp-panel');
  const list = document.getElementById('zk-esp-list');

  if (dataEl && panel && list) {
    const data: Espec[] = JSON.parse(dataEl.textContent || '[]');
    const rows = Array.from(list.querySelectorAll<HTMLButtonElement>('.zk-esp__row'));

    const goContacto = (sede: string) => {
      const sel = document.querySelector<HTMLSelectElement>('#zk-contact-sede');
      if (sel) sel.value = sede;
      const el = document.getElementById('contacto');
      if (el) window.scrollTo({ top: el.getBoundingClientRect().top + window.scrollY - 12, behavior: 'smooth' });
    };

    const render = (i: number) => {
      const s = data[i];
      if (!s) return;
      panel.style.animation = 'none';
      void panel.offsetWidth;
      panel.style.animation = 'zkfade .4s var(--ease-out)';

      const btns = s.contacts
        .map(
          (c) =>
            `<button type="button" class="zk-esp__contact" data-sede="${c.sede}" style="background:${c.grad}">Contacto - ${c.city}</button>`
        )
        .join('');

      panel.innerHTML = `
        <div class="zk-esp__panel-body">
          <p class="zk-esp__sede" style="color:${s.sedeColor}">${s.sedeLine}</p>
          <h3 class="zk-esp__title">${s.title}</h3>
          <p class="zk-esp__desc" style="color:${s.descColor}">${s.descText}</p>
        </div>
        <div class="zk-esp__actions">${btns}</div>`;

      panel.querySelectorAll<HTMLButtonElement>('.zk-esp__contact').forEach((b) =>
        b.addEventListener('click', () => goContacto(b.dataset.sede || ''))
      );

      rows.forEach((r, j) => {
        const active = j === i;
        r.setAttribute('aria-selected', active ? 'true' : 'false');
        r.classList.toggle('is-active', active);
      });
    };

    rows.forEach((r) => r.addEventListener('click', () => render(Number(r.dataset.idx))));

    // Accesos rápidos del hero → selecciona especialidad
    document.querySelectorAll<HTMLElement>('[data-espec-idx]').forEach((el) =>
      el.addEventListener('click', () => {
        const idx = Number(el.dataset.especIdx);
        if (!Number.isNaN(idx)) render(idx);
      })
    );

    render(0);
  }
</script>

<style>
  .zk-esp {
    padding: var(--space-9) 24px;
  }
  .zk-esp__grid {
    margin-top: 44px;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 56px;
    align-items: stretch;
  }
  .zk-esp__group {
    font-size: 11.5px;
    font-weight: var(--fw-semibold);
    letter-spacing: var(--ls-eyebrow);
    text-transform: uppercase;
    margin: 22px 0 4px;
    padding-left: 4px;
  }
  .zk-esp__row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 14px;
    width: 100%;
    text-align: left;
    background: none;
    border: none;
    cursor: pointer;
    padding: 14px 4px;
    border-bottom: 1px solid var(--border-subtle);
    font-family: var(--font-sans);
    color: var(--text-heading);
    transition: color 0.18s var(--ease-out);
  }
  .zk-esp__row:hover {
    color: var(--zk-teal-600);
  }
  .zk-esp__row.is-active {
    color: var(--zk-teal-600);
  }
  .zk-esp__row:focus-visible {
    outline: 2px solid var(--color-primary);
    outline-offset: 2px;
  }
  .zk-esp__name {
    font-size: 16.5px;
    font-weight: var(--fw-regular);
    flex: 1;
  }
  .zk-esp__row.is-active .zk-esp__name {
    font-weight: var(--fw-semibold);
  }

  .zk-esp__panel {
    position: relative;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    padding: 44px 48px;
    overflow: hidden;
    background: var(--surface-section);
  }
  .zk-esp__panel :global(.zk-esp__panel-body) {
    margin: auto 0;
    padding: 28px 0;
  }
  .zk-esp__panel :global(.zk-esp__sede) {
    font-size: 15px;
    margin: 0;
  }
  .zk-esp__panel :global(.zk-esp__title) {
    font-size: var(--fs-h1);
    font-weight: var(--fw-light);
    line-height: var(--lh-tight);
    margin: 8px 0 0;
    color: var(--text-heading);
  }
  .zk-esp__panel :global(.zk-esp__desc) {
    font-size: var(--fs-body-lg);
    line-height: var(--lh-body);
    margin: 22px 0 0;
    max-width: 460px;
  }
  .zk-esp__panel :global(.zk-esp__actions) {
    border-top: 1px solid var(--border-subtle);
    padding-top: 20px;
    display: flex;
    align-items: center;
    justify-content: flex-end;
    gap: 10px;
    flex-wrap: wrap;
  }
  .zk-esp__panel :global(.zk-esp__contact) {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 10px 18px;
    font-size: 14px;
    font-weight: var(--fw-regular);
    letter-spacing: 0.01em;
    font-family: var(--font-sans);
    color: #fff;
    border: none;
    border-radius: var(--radius-md);
    cursor: pointer;
    box-shadow: 0 2px 10px rgba(47, 63, 66, 0.2), inset 0 0 0 1px rgba(255, 255, 255, 0.16);
    transition: filter 0.18s var(--ease-out), transform 0.18s var(--ease-out);
  }
  .zk-esp__panel :global(.zk-esp__contact:hover) {
    filter: brightness(1.07);
  }
  .zk-esp__panel :global(.zk-esp__contact:active) {
    filter: brightness(0.95);
    transform: translateY(1px);
  }

  @media (max-width: 860px) {
    .zk-esp__grid {
      grid-template-columns: 1fr;
      gap: 32px;
    }
    .zk-esp__panel {
      min-height: 320px;
    }
  }
</style>

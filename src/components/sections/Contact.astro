---
import { Image } from 'astro:assets';
import logoHorizontal from '../../assets/brand/logo-zk-horizontal.png';
import Icon from '../core/Icon.astro';
import { waLaLink, waPuconLink } from '../../data/site';
---

<section id="contacto" class="zk-contact">
  <div class="zk-container">
    <div class="zk-contact__panel">
      <div class="zk-contact__aside">
        <Image src={logoHorizontal} alt="Clínica ZK" width={210} height={65} class="zk-contact__logo" />
        <h2 class="zk-contact__title">Contacto</h2>
        <div class="zk-contact__wa">
          <a href={waLaLink} target="_blank" rel="noopener" class="zk-contact__wa-link">
            <svg width="17" height="17" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.297-.347.446-.52.149-.174.198-.298.297-.497.1-.198.05-.371-.025-.52-.074-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.372-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.511-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.884 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z"/></svg>
            <strong>WhatsApp Los Ángeles</strong>
            <span class="zk-contact__wa-num">+56 9 5790 6641</span>
            <svg width="19" height="19" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M2.01 21 23 12 2.01 3 2 10l15 2-15 2z"/></svg>
          </a>
          <a href={waPuconLink} target="_blank" rel="noopener" class="zk-contact__wa-link">
            <svg width="17" height="17" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.297-.347.446-.52.149-.174.198-.298.297-.497.1-.198.05-.371-.025-.52-.074-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.372-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.511-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.884 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z"/></svg>
            <strong>WhatsApp Pucón</strong>
            <span class="zk-contact__wa-num">+56 9 5219 4952</span>
            <svg width="19" height="19" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M2.01 21 23 12 2.01 3 2 10l15 2-15 2z"/></svg>
          </a>
        </div>
      </div>

      <form id="zk-contact-form" class="zk-contact__form">
        <label>
          Nombre
          <input name="nombre" required placeholder="Tu nombre" autocomplete="name" />
        </label>
        <div class="zk-contact__row">
          <label>
            Correo
            <input name="correo" type="email" required placeholder="tucorreo@…" autocomplete="email" />
          </label>
          <label>
            Teléfono <span class="zk-contact__opt">(opcional)</span>
            <input name="telefono" placeholder="+56 9 …" autocomplete="tel" />
          </label>
        </div>
        <div class="zk-contact__row">
          <label>
            Motivo de contacto
            <select name="motivo">
              <option value="Agendar una hora">Agendar una hora</option>
              <option value="Membresías Familia ZK">Membresías Familia ZK</option>
              <option value="Exámenes radiológicos">Exámenes radiológicos</option>
              <option value="Urgencia dental">Urgencia dental</option>
              <option value="Convenios">Convenios</option>
              <option value="Otro">Otro</option>
            </select>
          </label>
          <label>
            Sede <span class="zk-contact__opt">(opcional)</span>
            <select name="sede" id="zk-contact-sede">
              <option value="">Selecciona una sede</option>
              <option value="Los Ángeles">Los Ángeles</option>
              <option value="Pucón">Pucón</option>
            </select>
          </label>
        </div>
        <label>
          Mensaje <span class="zk-contact__opt">(opcional)</span>
          <textarea name="mensaje" placeholder="Cuéntanos qué necesitas" rows="3"></textarea>
        </label>
        <button type="submit" class="zk-contact__submit">
          <Icon name="mail" size={17} />
          Enviar
        </button>
        <div class="zk-contact__note">Se abrirá tu correo hacia contacto@clinicazk.cl (dirección por confirmar).</div>
      </form>
    </div>
  </div>
</section>

<script>
  const form = document.getElementById('zk-contact-form') as HTMLFormElement | null;
  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    const data = new FormData(form);
    const g = (k: string) => String(data.get(k) || '');
    const nombre = g('nombre');
    const motivo = g('motivo');
    const subject = 'Contacto web — ' + (motivo || 'Consulta') + (nombre ? ' — ' + nombre : '');
    const body =
      'Nombre: ' + nombre + '\n' +
      'Correo: ' + g('correo') + '\n' +
      'Teléfono: ' + (g('telefono') || '—') + '\n' +
      'Motivo: ' + motivo + '\n' +
      'Sede: ' + (g('sede') || 'Sin preferencia') + '\n\n' +
      (g('mensaje') || 'Quisiera más información.');
    window.location.href =
      'mailto:contacto@clinicazk.cl?subject=' + encodeURIComponent(subject) + '&body=' + encodeURIComponent(body);
  });
</script>

<style>
  .zk-contact {
    padding: var(--space-9) 24px;
  }
  .zk-contact__panel {
    border-radius: var(--radius-lg);
    overflow: hidden;
    box-shadow: var(--shadow-raised);
    display: grid;
    grid-template-columns: 0.38fr 0.62fr;
  }
  .zk-contact__aside {
    background: var(--gradient-brand);
    padding: 48px 44px;
    position: relative;
    overflow: hidden;
    display: flex;
    flex-direction: column;
  }
  .zk-contact__aside :global(.zk-contact__logo) {
    width: 210px;
    height: auto;
    align-self: flex-start;
    filter: brightness(0) invert(1);
    margin-top: 26px;
  }
  .zk-contact__title {
    color: #fff;
    font-size: var(--fs-h1);
    font-weight: var(--fw-light);
    margin: auto 0;
    line-height: var(--lh-tight);
  }
  .zk-contact__wa {
    padding-top: 24px;
    margin-bottom: 14px;
    display: grid;
    grid-auto-rows: 1fr;
    gap: 10px;
  }
  .zk-contact__wa-link {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 13px 16px;
    background: rgba(255, 255, 255, 0.14);
    border: 1px solid rgba(255, 255, 255, 0.35);
    border-radius: var(--radius-md);
    color: #fff;
    text-decoration: none;
    font-size: 14.5px;
    line-height: 1.4;
    transition: background 0.18s var(--ease-out);
  }
  .zk-contact__wa-link:hover {
    background: rgba(255, 255, 255, 0.26);
    color: #fff;
    text-decoration: none;
  }
  .zk-contact__wa-link strong {
    font-weight: var(--fw-semibold);
  }
  .zk-contact__wa-link svg {
    flex: none;
  }
  .zk-contact__wa-num {
    margin-left: auto;
    padding-right: 12px;
    font-variant-numeric: tabular-nums;
    white-space: nowrap;
  }

  .zk-contact__form {
    background: var(--zk-white);
    padding: 44px 48px;
    display: flex;
    flex-direction: column;
    gap: 14px;
  }
  .zk-contact__row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 14px;
  }
  .zk-contact__form label {
    font-size: 13px;
    font-weight: var(--fw-semibold);
    color: var(--text-heading);
  }
  .zk-contact__opt {
    font-weight: var(--fw-regular);
    color: var(--text-muted);
  }
  .zk-contact__form input,
  .zk-contact__form select,
  .zk-contact__form textarea {
    margin-top: 6px;
    width: 100%;
    box-sizing: border-box;
    padding: 11px 12px;
    font-size: 15px;
    font-family: var(--font-sans);
    color: var(--text-body);
    border: 1px solid var(--border-subtle);
    border-radius: 6px;
    background: #fff;
  }
  .zk-contact__form textarea {
    resize: vertical;
  }
  .zk-contact__form input:focus,
  .zk-contact__form select:focus,
  .zk-contact__form textarea:focus {
    outline: none;
    border-color: var(--color-primary);
    box-shadow: var(--focus-ring);
  }
  .zk-contact__submit {
    margin-top: 10px;
    padding: 13px 20px;
    font-size: 15px;
    font-weight: var(--fw-semibold);
    font-family: var(--font-sans);
    color: #fff;
    background: var(--color-primary);
    border: none;
    border-radius: var(--radius-md);
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    transition: background var(--duration-fast) var(--ease-out);
  }
  .zk-contact__submit:hover {
    background: var(--zk-teal-700);
  }
  .zk-contact__note {
    font-size: 12px;
    color: var(--text-muted);
    text-align: center;
  }

  @media (max-width: 860px) {
    .zk-contact__panel {
      grid-template-columns: 1fr;
    }
    .zk-contact__aside {
      padding: 40px 28px;
    }
    .zk-contact__title {
      margin: 20px 0;
    }
    .zk-contact__form {
      padding: 36px 28px;
    }
  }
  @media (max-width: 480px) {
    .zk-contact__row {
      grid-template-columns: 1fr;
    }
  }
</style>

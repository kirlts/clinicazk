---
import SectionHeader from '../core/SectionHeader.astro';
import Button from '../core/Button.astro';
import BranchSplit from '../content/BranchSplit.astro';
import { waLaLink, waPuconLink } from '../../data/site';
---

<section id="sucursales" class="zk-branches">
  <div class="zk-container">
    <SectionHeader align="left" title="Sucursales" />
    <div class="zk-branches__frame">
      <BranchSplit height={460} />
    </div>
    <div class="zk-branches__ctas">
      <Button href={waLaLink}>WhatsApp Los Ángeles</Button>
      <Button variant="outline" href={waPuconLink}>WhatsApp Pucón</Button>
    </div>
  </div>
</section>

<style>
  .zk-branches {
    background: var(--surface-section);
    padding: var(--space-9) 24px;
  }
  .zk-branches__frame {
    margin-top: 32px;
    border-radius: var(--radius-lg);
    overflow: hidden;
    box-shadow: var(--shadow-card);
  }
  .zk-branches__ctas {
    margin-top: 28px;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 16px;
  }
</style>

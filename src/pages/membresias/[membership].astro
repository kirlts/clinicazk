---
import Layout from '../../layouts/Layout.astro';
import SiteHeader from '../../components/site/SiteHeader.astro';
import SiteFooter from '../../components/site/SiteFooter.astro';
import WhatsAppFab from '../../components/site/WhatsAppFab.astro';
import MembershipPoster from '../../components/content/MembershipPoster.astro';
import { MEMBERSHIP_KEYS, getMembershipDetail } from '../../data/membershipDetails';
import type { MembershipKey } from '../../data/membershipDetails';

export function getStaticPaths() {
  return MEMBERSHIP_KEYS.map((membership) => ({ params: { membership } }));
}

const { membership } = Astro.params as { membership: MembershipKey };
const d = getMembershipDetail(membership);

const ACCENTS: Record<MembershipKey, string> = {
  anticipa: 'var(--zk-anticipa)',
  familia: 'var(--zk-familia)',
  seguimiento: 'var(--zk-seguimiento)',
  total: 'var(--zk-total)',
};
---

<Layout
  title={`${d.name} — Familia ZK | Clínica ZK`}
  description={`${d.tagline} Conoce los beneficios, la ruta de cuidado y cómo activar la membresía ${d.name} de Familia ZK.`}
>
  <SiteHeader />
  <main>
    <section class="zk-mpage">
      <div class="zk-container">
        <a href={`${import.meta.env.BASE_URL}#membresias`} class="zk-mpage__back">← Volver a Membresías</a>

        <div class="zk-mpage__switcher" role="tablist" aria-label="Elegir membresía">
          {MEMBERSHIP_KEYS.map((key) => (
            <a
              href={`${import.meta.env.BASE_URL}membresias/${key}/`}
              role="tab"
              aria-selected={key === membership}
              class="zk-mpage__tab"
              data-active={key === membership ? '' : undefined}
              style={`--tab-accent:${ACCENTS[key]}`}
            >
              {getMembershipDetail(key).name}
            </a>
          ))}
        </div>

        <MembershipPoster membership={membership} />

        <div class="zk-mpage__cta">
          <p>¿Esta membresía va contigo?</p>
          <a
            class="zk-mpage__cta-link"
            href={`https://wa.me/56952194952?text=${encodeURIComponent(`Hola, quisiera más información sobre la membresía ${d.name}.`)}`}
            target="_blank"
            rel="noopener"
          >
            Consultar por WhatsApp
          </a>
        </div>
      </div>
    </section>
  </main>
  <SiteFooter />
  <WhatsAppFab />
</Layout>

<style>
  .zk-mpage {
    padding: 48px 24px var(--space-9);
    background: var(--surface-section);
  }
  .zk-mpage__back {
    display: inline-block;
    font-size: 14px;
    font-weight: var(--fw-semibold);
    color: var(--text-body);
    margin-bottom: 24px;
  }
  .zk-mpage__switcher {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-bottom: 32px;
  }
  .zk-mpage__tab {
    padding: 9px 18px;
    border-radius: var(--radius-pill);
    border: 1.5px solid var(--tab-accent);
    color: var(--tab-accent);
    font-size: 14px;
    font-weight: var(--fw-semibold);
    text-decoration: none;
  }
  .zk-mpage__tab:hover {
    text-decoration: none;
    background: var(--zk-gray-50);
  }
  .zk-mpage__tab[data-active] {
    background: var(--tab-accent);
    color: #fff;
  }
  .zk-mpage__cta {
    max-width: 794px;
    margin: 40px auto 0;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    flex-wrap: wrap;
    background: var(--zk-white);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-card);
    padding: 22px 28px;
  }
  .zk-mpage__cta p {
    margin: 0;
    font-size: 16px;
    font-weight: var(--fw-semibold);
    color: var(--text-heading);
  }
  .zk-mpage__cta-link {
    display: inline-flex;
    align-items: center;
    padding: 12px 24px;
    background: var(--zk-whatsapp);
    color: #fff;
    font-weight: var(--fw-semibold);
    border-radius: var(--radius-pill);
    text-decoration: none;
  }
  .zk-mpage__cta-link:hover {
    color: #fff;
    text-decoration: none;
    opacity: 0.9;
  }
</style>

---
const base = import.meta.env.BASE_URL;
---

<div class="zk-afiche-modal" id="zk-afiche-modal" data-base={base} hidden>
  <div class="zk-afiche-modal__inner">
    <iframe id="zk-afiche-frame" title="Detalle de membresía" src="about:blank"></iframe>
  </div>
</div>

<script>
  const modal = document.getElementById('zk-afiche-modal');
  const frame = document.getElementById('zk-afiche-frame') as HTMLIFrameElement | null;
  if (modal && frame) {
    const base = modal.dataset.base || '/';
    let lastFocus: HTMLElement | null = null;

    const open = (m: string) => {
      lastFocus = document.activeElement as HTMLElement;
      frame.src = `${base}afiche/${m}/`;
      modal.hidden = false;
      document.body.style.overflow = 'hidden';
    };
    const close = () => {
      modal.hidden = true;
      frame.src = 'about:blank';
      document.body.style.overflow = '';
      if (lastFocus) lastFocus.focus();
    };

    // "Ver más" de cada tarjeta de membresía
    document.querySelectorAll<HTMLElement>('[data-afiche-open]').forEach((el) =>
      el.addEventListener('click', (e) => {
        e.preventDefault();
        open(el.dataset.aficheOpen || '');
      })
    );

    // Clic fuera de la hoja
    modal.addEventListener('click', (e) => {
      if (e.target === modal) close();
    });
    // Esc
    window.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && !modal.hidden) close();
    });
    // Cierre desde dentro del iframe ("Volver al sitio")
    window.addEventListener('message', (e) => {
      if (e.data === 'zk-close-afiche') close();
    });
  }
</script>

<style>
  .zk-afiche-modal {
    position: fixed;
    inset: 0;
    z-index: 90;
    background: color-mix(in srgb, #1e4744 55%, transparent);
    backdrop-filter: blur(3px);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 40px;
    animation: zkfade 0.25s var(--ease-out);
  }
  .zk-afiche-modal[hidden] {
    display: none;
  }
  .zk-afiche-modal__inner {
    position: relative;
    width: min(880px, 94vw);
    height: 100vh;
  }
  .zk-afiche-modal__inner iframe {
    width: 100%;
    height: 100%;
    border: none;
    display: block;
    background: transparent;
  }

  @media (max-width: 620px) {
    .zk-afiche-modal {
      padding: 16px;
    }
  }
</style>

---
import SectionHeader from '../core/SectionHeader.astro';
import Button from '../core/Button.astro';
import Icon from '../core/Icon.astro';
import { waPuconLink } from '../../data/site';
---

<section id="convenios" class="zk-agreements">
  <div class="zk-container zk-agreements__grid">
    <div>
      <SectionHeader align="left" title="Convenios" />
      <p class="zk-agreements__text">
        Trabajamos con convenios locales para que cuidar tu salud dental sea más simple. Escríbenos y confirmamos si el tuyo aplica en tu sucursal.
      </p>
      <div class="zk-agreements__cta">
        <Button variant="outline" href={waPuconLink}>Consulta tu convenio</Button>
      </div>
    </div>
    <div class="zk-agreements__note">
      <span class="zk-agreements__icon">
        <Icon name="handshake" size={28} />
      </span>
      <div class="zk-agreements__note-text">
        Listado de convenios vigentes <strong>pendiente</strong> de confirmación del equipo. No publicamos convenios que no estén activos.
      </div>
    </div>
  </div>
</section>

<style>
  .zk-agreements {
    padding: var(--space-9) 24px;
  }
  .zk-agreements__grid {
    display: grid;
    grid-template-columns: 1fr 0.9fr;
    gap: 48px;
    align-items: center;
  }
  .zk-agreements__text {
    font-size: var(--fs-body-lg);
    color: var(--text-body);
    margin-top: 20px;
    max-width: 480px;
    line-height: var(--lh-body);
  }
  .zk-agreements__cta {
    margin-top: 24px;
  }
  .zk-agreements__note {
    background: var(--surface-section);
    border-top: 3px solid var(--color-secondary);
    padding: 28px 30px;
  }
  .zk-agreements__icon {
    color: var(--color-secondary);
    display: inline-flex;
  }
  .zk-agreements__note-text {
    font-size: 15px;
    color: var(--text-body);
    margin-top: 12px;
    line-height: var(--lh-body);
  }

  @media (max-width: 900px) {
    .zk-agreements__grid {
      grid-template-columns: 1fr;
      gap: 32px;
    }
  }
</style>
